@{
    ViewData["Title"] = "Home Page";
}

<section class="catalog-hero">
    <h1 class="catalog-title">Catálogo Express</h1>
    <p class="catalog-subtitle">Seleccioná un producto para ver el detalle.</p>
</section>

<section class="product-grid">
    <p> TODO:
       - Recorrer la lista de productos (ej: Model)!
       - Por cada uno mostrar su nombre y precio
       - En cada producto agregar un link al detalle (ej: @Url.Action("Detalle","Productos", new { nombre = producto.ObtenerNombre() }))
       
    
    </p>
    @{
        forEach(Producto producto in ViewBag.Catalogo())
        {
            <a>@Url.Action("Detalle","Productos", new { nombre = producto.ObtenerNombre() }))
        }
    }
</section>